CELERY_RESULT_BACKEND=redis://redis:6379/0

# Task signing — Ed25519 private key seed (base64-encoded 32 bytes)
# Generate: python -c "import base64; from nacl.signing import SigningKey; print(base64.b64encode(bytes(SigningKey.generate())).decode())"
VIGIL_SIGNING_KEY_SEED=
