# Vigil Server Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in values before running `docker compose up -d`.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Django ────────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to false in production.
DJANGO_DEBUG=false

# Comma-separated list of hostnames/IPs the server accepts requests for.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: set to the public URL for proper absolute URLs in emails/links.
# DJANGO_SITE_URL=https://vigil.example.com


# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=vigil
POSTGRES_USER=vigil
# Use a strong random password in production.
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ── Redis / Celery ────────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ── Task Signing ──────────────────────────────────────────────────────────────
#
# Ed25519 signing key seed — base64-encoded 32 random bytes (44 chars, ending
# in '='). Every task dispatched to agents is signed with this key; agents
# verify signatures before executing. Rotate only during a maintenance window
# (every enrolled agent will need to delete its server_public_key.pin and
# re-pin the new key).
#
# Generate:
#   python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
#
# Verify the value you pasted is valid base64 of 32 bytes:
#   python3 -c "import base64,sys; print(len(base64.b64decode(sys.argv[1])))" "<paste-seed-here>"
#   # Expect: 32
#
# IMPORTANT — Portainer / YAML stack editors: do NOT inline the seed into
# docker-compose.yml as a bare value. The trailing '=' is base64 padding and
# is silently stripped by some YAML parsers. Either:
#   (a) set it via Portainer's "Environment variables" tab, or
#   (b) wrap the value in double quotes when pasted into YAML.
# A malformed seed throws binascii.Error: Incorrect padding inside
# get_signing_key() and 500s every checkin in the fleet.
VIGIL_SIGNING_KEY_SEED=


# ── Email (optional) ──────────────────────────────────────────────────────────
#
# Used for alert notifications and password reset emails.
# Leave blank to disable email sending.
#
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=vigil@example.com
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Vigil <vigil@example.com>
