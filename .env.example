# Vigil Server Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in values before running `docker compose up -d`.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Django ────────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key

# Set to false in production.
DJANGO_DEBUG=false

# Comma-separated list of hostnames/IPs the server accepts requests for.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: set to the public URL for proper absolute URLs in emails/links.
# DJANGO_SITE_URL=https://vigil.example.com


# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=vigil
POSTGRES_USER=vigil
# Use a strong random password in production.
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432


# ── Redis / Celery ────────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ── Task Signing ──────────────────────────────────────────────────────────────
#
# Ed25519 signing key seed — base64-encoded 32 random bytes.
# Every task dispatched to agents is signed with this key; agents verify
# signatures before executing. Rotate only during a maintenance window
# (all agents will need to re-pin the new public key).
#
# Generate:
#   python -c "
#   import base64
#   from nacl.signing import SigningKey
#   print(base64.b64encode(bytes(SigningKey.generate())).decode())
#   "
VIGIL_SIGNING_KEY_SEED=


# ── Email (optional) ──────────────────────────────────────────────────────────
#
# Used for alert notifications and password reset emails.
# Leave blank to disable email sending.
#
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=vigil@example.com
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Vigil <vigil@example.com>
